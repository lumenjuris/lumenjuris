// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

//==== ENUM ====

enum Role{
  USER
  ADMIN
}

enum AuthProvider{
  GOOGLE
}

enum SubscriptionStatus{
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}


//==== CREATION DES MODELS ====

// Utilisateurs
model User{
  idUser                Int     @id @default(autoincrement())
  role                  Role    @default(USER)
  email                 String  @unique
  nom                   String 
  prenom                String
  isVerified            Boolean @default(false)
  avatarUrl             String?
  stripeCustomerId      String?

  //relation 
  tokens                Token[]
  events                Event[]
  authProviders         AuthProviderAccount[]
  subscription          Subscription[]

  enterpriseId          Int?
  enterprise            Enterprise? @relation(fields: [enterpriseId], references: [idEnterprise])

  userCredit            UserCredit?
}


//Entreprise
model Enterprise{
  idEnterprise          Int     @id @default(autoincrement())
  siren                 String?
  codeNaf               String?
  name                  String
  conventionCollective  String
  statusJurisique       String

  //relation
  users                 User[]
  address               Address?
}


model Address{
  idAddress             Int @id @default(autoincrement())
  address               String
  codePostal            String
  pays                  String @default("France")

  enterpriseId          Int?
  enterprise            Enterprise? @relation(fields : [enterpriseId], references : [idEnterprise])
}



//Synchronisation provider
model AuthProviderAccount{
  idAuthProvider        Int @id @default(autoincrement())
  providerId            String
  provider              AuthProvider

  //relation
  userId                Int
  user                  User @relation(fields : [userId], references : [idUser])
}



//Sécurité (token)
model Token{
  idToken               Int @id @default(autoincrement())
  token                 String @unique
  expiresAt             DateTime

  //relation
  userId                Int
  user                  User @relation(fields : [userId], references : [idUser]) 
}



//Gestion d'événement
model Event{
  idEvent               Int @id @default(autoincrement())
  type                  String
  state                 String
  expiresAt             DateTime

  //relation
  userId                Int
  user                  User @relation(fields : [userId], references : [idUser])
  Document              Document?
}


model Document{
  idDocument            Int @id @default(autoincrement())
  type                  String
  templateContent       String @db.text

  //relation
  eventId               Int?
  event                 Event? @relation(fields : [eventId], references : [idEvent])
}



//Gestion credit et payment
model UserCredit{
  idUserCredit          Int @id @default(autoincrement())
  creditSignature       Int
  creditAnalyse         Int
  creditGenerationDoc   Int

  //relation
  subscriptionId        Int @unique
  subscription          Subscription @relation(fields: [subscriptionId], references: [idSubscription])

  userId                Int @unique
  user                  User @relation(fields: [userId], references: [idUser])           
}


model Subscription{
  idSubscription        Int @id @default(autoincrement())
  status                SubscriptionStatus
  startAt               DateTime
  expiresAt             DateTime
  stripeSubscriptionId  String?
  stripePriceId         String?

  //relation
  userId                Int
  user                  User @relation(fields: [userId], references: [idUser])  

  planId                Int
  plan                  Plan @relation(fields: [planId], references: [idPlan])

  userCredit            UserCredit?
  facture               Facture[]
}

model Plan{
  idPlan                Int @id @default(autoincrement())
  name                  String
  price                 Int
  interval              String
  creditSignature       Int
  creditGenerationDoc   Int
  creditAnalyse         Int

  //relation
  subscription          Subscription[]
}


model Facture{
  idFacture             Int @id @default(autoincrement())
  price                 Int
  stripeInvoiceId       String
  createdAt             DateTime @default(now())

  //relation

  subscriptionId        Int
  subscription          Subscription @relation(fields: [subscriptionId], references : [idSubscription])
}




// --- RESSOURCE LLM ---

model Llm{
  idLlm                 Int     @id @default(autoincrement())
  name                  String
  tokenPrice            Float

  llmUsage              LlmUsage[] 
}

model LlmUsage{
  idLlmUsage            Int     @id @default(autoincrement())
  startAt               DateTime
  expiresAt             DateTime
  totalCost             Int
  tokenInput            Int
  tokenOutput           Int

  //relation
  llmId                 Int
  llm                   Llm @relation(fields : [llmId], references : [idLlm])
}